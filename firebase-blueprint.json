{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Represents a registered user profile with role configuration",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "free", "premium"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "UserSettings": {
      "title": "Trip (User Settings)",
      "description": "Refers to a specific learning trip configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "learningGoal": { "type": "string" },
        "psychology": { "type": "object" },
        "dailyDuration": { "type": "integer" },
        "learningDays": { "type": "array" },
        "theme": { "type": "string" },
        "gameData": { "type": "object" },
        "unlockedStationIds": { "type": "array" },
        "isFree": { "type": "boolean" }
      },
      "required": ["id", "learningGoal"]
    },
    "Station": {
      "title": "Station",
      "description": "Represents a physical station in a trip",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "description": { "type": "string" },
        "targetDate": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["id", "name"]
    },
    "Task": {
      "title": "Task",
      "description": "Represents a checklist activity/task under a station",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "stationId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "duration": { "type": "integer" },
        "isCompleted": { "type": "boolean" },
        "activities": { "type": "array" }
      },
      "required": ["id", "title", "stationId"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback, complaints, and ratings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "type": { "type": "string", "enum": ["complaint", "rating", "suggestion"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "rating", "type", "createdAt"]
    },
    "Ad": {
      "title": "Ad",
      "description": "Advertisement content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "targetUrl": { "type": "string" },
        "position": { "type": "string", "enum": ["top", "bottom"] },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "title", "text", "position", "isActive"]
    },
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "description": "User XP summary for leaderboard",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userName": { "type": "string" },
        "xp": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userName", "xp", "lastUpdated"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection containing system roles and credentials"
    },
    "/users/{userId}/userSettings/{settingId}": {
      "schema": "UserSettings",
      "description": "Trips assigned to or created for a specific user"
    },
    "/users/{userId}/stations/{stationId}": {
      "schema": "Station",
      "description": "Trip station paths assigned to the user"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks associated with stations for a specific user"
    },
    "/users/{userId}/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback and complaints"
    },
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "Advertising content managed by admins"
    },
    "/leaderboard/{userId}": {
      "schema": "LeaderboardEntry",
      "description": "Aggregated XP data for top users"
    },
    "/publicTrips/{tripId}": {
      "schema": "UserSettings",
      "description": "Global directory of free trips accessible to Premium users"
    },
    "/publicTrips/{tripId}/stations/{stationId}": {
      "schema": "Station",
      "description": "Global directory of stations for free trips"
    },
    "/publicTrips/{tripId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Global directory of tasks for free trips"
    }
  }
}
