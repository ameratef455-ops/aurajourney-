rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Admin helper
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "ameratef455@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // Users and roles
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Prevent self-assigned roles during signup
      allow create: if isSignedIn() && request.auth.uid == userId && (
        (request.auth.token.email == "ameratef455@gmail.com" && request.resource.data.role == "admin") ||
        (request.auth.token.email != "ameratef455@gmail.com" && request.resource.data.role == "free")
      );
      
      // Enforce immutability of roles for non-admin owners
      allow update: if isSignedIn() && (
        isAdmin() || (
          request.auth.uid == userId && 
          request.resource.data.role == resource.data.role
        )
      );
      
      allow delete: if isAdmin();

      // Trips (userSettings) subcollection
      match /userSettings/{settingId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // Stations subcollection
      match /stations/{stationId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // Tasks subcollection
      match /tasks/{taskId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // Reflections subcollection
      match /reflections/{reflectionId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // Stumbles subcollection
      match /stumbles/{stumbleId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // Notifications subcollection
      match /notifications/{notificationId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // Feedbacks subcollection
      match /feedbacks/{feedbackId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    // Global Free Trips directory (any signed-in user can browse, only admin can write)
    match /publicTrips/{tripId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /stations/{stationId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
      
      match /tasks/{taskId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // Global Ads system
    match /ads/{adId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Dynamic Leaderboard (read globally by players, write owned or by admin)
    match /leaderboard/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
  }
}
